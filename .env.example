# ──────────────────────────────────────────────────────────────
# AI Email Generator — Environment Variables
# ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Lines starting with # are comments. All values after = are defaults.

# ──────────────────────────────────────────────────────────────
# PostgreSQL Database
# ──────────────────────────────────────────────────────────────
# Name of the Postgres database created on startup
POSTGRES_DB=ai_email_db

# Postgres superuser credentials
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ──────────────────────────────────────────────────────────────
# Spring Data Source (Backend → Database connection)
# ──────────────────────────────────────────────────────────────
# JDBC connection URL. Use "postgres" as the host when running in Docker.
DATABASE_URL=jdbc:postgresql://localhost:5432/ai_email_db

# Credentials the backend uses to connect to Postgres
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# ──────────────────────────────────────────────────────────────
# Security / JWT
# ──────────────────────────────────────────────────────────────
# Base64-encoded secret key for HMAC-SHA512 JWT signing.
# Generate your own: openssl rand -base64 64
JWT_SECRET=dGhpcy1pcy1hLXNlY3JldC1rZXktZm9yLWp3dC10b2tlbi1nZW5lcmF0aW9uLXBsZWFzZS1jaGFuZ2UtaXQtaW4tcHJvZHVjdGlvbg==

# Token time-to-live in milliseconds (default: 24 hours)
JWT_EXPIRATION=86400000

# ──────────────────────────────────────────────────────────────
# Groq API Keys
# ──────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# Gemini model to use (default: gemini-1.5-flash)
GEMINI_MODEL=gemini-1.5-flash

# ──────────────────────────────────────────────────────────────
# Spring Boot
# ──────────────────────────────────────────────────────────────
# Active profile: dev | prod
SPRING_PROFILES_ACTIVE=dev

# ──────────────────────────────────────────────────────────────
# Frontend (Vite)
# ──────────────────────────────────────────────────────────────
# Base URL for the backend API (used by Axios in the React app)
VITE_API_BASE_URL=http://localhost:8080
